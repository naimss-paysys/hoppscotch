# ══════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════
# IMPORTANT: No special characters in password — Prisma breaks on @ in URL
POSTGRES_USER=hoppscotch
POSTGRES_PASSWORD=hoppscotch123
POSTGRES_DB=hoppscotch
DATABASE_URL=postgresql://hoppscotch:hoppscotch123@postgres-hopps:5432/hoppscotch

# ══════════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════════
REDIS_URL=redis://:redis123@redis:6379

# ══════════════════════════════════════════════
# JWT / SESSION SECRETS
# Must be at least 32 characters, alphanumeric only
# ══════════════════════════════════════════════
JWT_SECRET=paysyslabsjwtsecretkey32charslong
REFRESH_TOKEN_SECRET=paysyslabsrefreshtokensecret32ch
SESSION_SECRET=paysyslabssessionsecret32charss
DATA_ENCRYPTION_KEY=paysyslabsenckey1234567890abcdef

# ══════════════════════════════════════════════
# PUBLIC URLs — the only two vars to update per environment
# Local:   PUBLIC_URL=http://api.paysyslabs.com:8090
#          PUBLIC_WS_URL=ws://api.paysyslabs.com:8090
# Tunnel:  run ./tunnel-restart.sh — sets both automatically
# ══════════════════════════════════════════════
PUBLIC_URL=https://dander-pork-headgear.ngrok-free.dev
PUBLIC_WS_URL=wss://dander-pork-headgear.ngrok-free.dev

VITE_APP_TOS_LINK=
VITE_APP_PRIVACY_POLICY_LINK=

# ══════════════════════════════════════════════
# COOKIES — true when accessed via Cloudflare (HTTPS)
#           false for local HTTP access
# tunnel-restart.sh sets this automatically
# ══════════════════════════════════════════════
ALLOW_SECURE_COOKIES=true

# ══════════════════════════════════════════════
# ADMIN
# ══════════════════════════════════════════════
FIRST_ADMIN_EMAIL=admin@paysyslabs.com

# ══════════════════════════════════════════════
# MAILER — SMTP bridge → PaysysLabs email API
# ══════════════════════════════════════════════
MAILER_SMTP_ENABLE=true
MAILER_SMTP_URL=smtp://smtp-bridge:1025
MAILER_ADDRESS_FROM="Hoppscotch <watcher@paysyslabs.com>"


# ══════════════════════════════════════════════
# AUTH PROVIDERS
# ══════════════════════════════════════════════
VITE_ALLOWED_AUTH_PROVIDERS=email,github

# ══════════════════════════════════════════════
# GITHUB OAUTH
# GITHUB_CALLBACK_URL is set in docker-compose.yaml via TUNNEL_HOST
# ══════════════════════════════════════════════
NGROK_AUTHTOKEN=3CsmSsxWwU8pGMAJz2E7W3kCugf_4NDsxEidLLpL7YUtCH6wy

GITHUB_CLIENT_ID=Ov23lijwBxDFmHE9GU8L
GITHUB_CLIENT_SECRET=0ca60ecb6202e4418ed14da104ac0d6889847bce
GITHUB_SCOPE=user:email

# ══════════════════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════════════════
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
