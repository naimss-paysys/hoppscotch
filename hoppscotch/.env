# ══════════════════════════════════════════════
# DATABASE
# ══════════════════════════════════════════════
# IMPORTANT: No special characters in password — Prisma breaks on @ in URL
POSTGRES_USER=hoppscotch
POSTGRES_PASSWORD=REDACTED_DB_PASS
POSTGRES_DB=hoppscotch
DATABASE_URL=postgresql://hoppscotch:REDACTED_DB_PASS@postgres-hopps:5432/hoppscotch

# ══════════════════════════════════════════════
# REDIS
# ══════════════════════════════════════════════
REDIS_URL=redis://:REDACTED_REDIS_PASS@redis:6379

# ══════════════════════════════════════════════
# JWT / SESSION SECRETS
# Must be at least 32 characters, alphanumeric only
# ══════════════════════════════════════════════
JWT_SECRET=REDACTED_JWT_SECRET
REFRESH_TOKEN_SECRET=REDACTED_REFRESH_SECRET
SESSION_SECRET=REDACTED_SESSION_SECRET
DATA_ENCRYPTION_KEY=REDACTED_ENC_KEY

# ══════════════════════════════════════════════
# FRONTEND URLs (VITE_ prefix = exposed to browser)
# ══════════════════════════════════════════════
VITE_BASE_URL=http://api.paysyslabs.com:8090
VITE_SHORTCODE_BASE_URL=http://api.paysyslabs.com:8090
VITE_ADMIN_URL=http://api.paysyslabs.com:8091
VITE_BACKEND_GQL_URL=http://api.paysyslabs.com:8090/api/graphql
VITE_BACKEND_WS_URL=ws://api.paysyslabs.com:8090/api/graphql
VITE_BACKEND_API_URL=http://api.paysyslabs.com:8090/api
VITE_APP_TOS_LINK=
VITE_APP_PRIVACY_POLICY_LINK=

# ══════════════════════════════════════════════
# BACKEND CORS / ORIGIN WHITELIST
# CRITICAL: Missing this causes crash:
# "TypeError: Cannot read properties of undefined (reading 'split')"
# ══════════════════════════════════════════════
WHITELISTED_ORIGINS=http://api.paysyslabs.com:8090,http://api.paysyslabs.com:8091,http://REDACTED_SERVER_IP:8090,http://REDACTED_SERVER_IP:8091,http://localhost:8090

# ══════════════════════════════════════════════
# COOKIES — must be false for HTTP (no SSL)
# ══════════════════════════════════════════════
ALLOW_SECURE_COOKIES=false

# ══════════════════════════════════════════════
# ADMIN
# ══════════════════════════════════════════════
FIRST_ADMIN_EMAIL=admin@paysyslabs.com

# ══════════════════════════════════════════════
# MAILER — SMTP bridge → PaysysLabs email API
# ══════════════════════════════════════════════
MAILER_SMTP_ENABLE=true
MAILER_SMTP_URL=smtp://smtp-bridge:1025
MAILER_ADDRESS_FROM="Hoppscotch <watcher@paysyslabs.com>"


# ══════════════════════════════════════════════
# AUTH PROVIDERS
# ══════════════════════════════════════════════
VITE_ALLOWED_AUTH_PROVIDERS=email,github

# ══════════════════════════════════════════════
# GITHUB OAUTH
# ══════════════════════════════════════════════
GITHUB_CLIENT_ID=REDACTED_GITHUB_CLIENT_ID
GITHUB_CLIENT_SECRET=REDACTED_GITHUB_SECRET
GITHUB_CALLBACK_URL=http://api.paysyslabs.com:8090/api/auth/github/callback
GITHUB_SCOPE=user:email

# ══════════════════════════════════════════════
# RATE LIMITING
# ══════════════════════════════════════════════
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100